{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "dom"],
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["cypress"],
    "typeRoots": ["../node_modules/@types", "../node_modules"]
  },
  "include": ["**/*.ts"]
}
